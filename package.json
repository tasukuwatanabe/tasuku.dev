    "@tailwindcss/vite": "^4.2.2",
    "cheerio": "^1.1.0",
    "lefthook": "^2.1.4",
    "oxlint": "^1.56.0",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.1",
