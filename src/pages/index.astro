---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import { getCollection } from "astro:content";
import ArticleCard from "../components/ArticleCard.astro";
import { getBlogUrl } from "../utils/slug";
import type {
  QiitaArticle,
  ZennArticle,
  SpeakerDeckSlide,
  ArticleItem,
} from "../types/articles";

const posts = await getCollection("blog");

// Combine all blog posts into one section
const allBlogItems: ArticleItem[] = posts
  .map((post) => ({
    type: "blog" as const,
    title: post.data.title,
    description: post.data.description,
    pubDate: post.data.pubDate,
    url: getBlogUrl(post.id),
    post,
  }))
  .sort((a, b) => b.pubDate.getTime() - a.pubDate.getTime());

// Import Qiita articles from the JSON file
import qiitaArticlesData from "../data/qiita-articles.json";
const qiitaArticles: QiitaArticle[] = qiitaArticlesData;

// Import Zenn articles from the JSON file
import zennArticlesData from "../data/zenn-articles.json";
const zennArticles: ZennArticle[] = zennArticlesData;

// Import SpeakerDeck slides from the JSON file
import speakerdeckSlidesData from "../data/speakerdeck-slides.json";
const speakerdeckSlides: SpeakerDeckSlide[] = speakerdeckSlidesData;
---

<!doctype html>
<html lang="ja" class="h-full">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="max-w-6xl mx-auto px-4 flex-grow">
      {/* Blog Section: hidden until real articles are available */}
      {
        /* <section class="mb-16">
        <h2 class="section-title">Blog</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {
            allBlogItems.map((item) => (
              <ArticleCard
                title={item.title}
                url={item.url}
                date={item.pubDate}
              />
            ))
          }
        </div>
      </section> */
      }

      <!-- Zenn Section -->
      <section class="mb-16">
        <h2 class="section-title">Zenn</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {
            zennArticles.map((article) => (
              <ArticleCard
                title={article.title}
                url={article.url}
                date={article.published_at}
                thumbnail={article.ogImage}
                external={true}
              />
            ))
          }
        </div>
      </section>

      <!-- Qiita Section -->
      <section class="mb-16">
        <h2 class="section-title">Qiita</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {
            qiitaArticles.map((article) => (
              <ArticleCard
                title={article.title}
                url={article.url}
                date={article.created_at}
                thumbnail={article.ogImage}
                external={true}
              />
            ))
          }
        </div>
      </section>

      <!-- SpeakerDeck Section -->
      <section class="mb-16">
        <h2 class="section-title">SpeakerDeck</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {
            speakerdeckSlides.map((slide) => (
              <ArticleCard
                title={slide.title}
                url={slide.url}
                date={slide.published_at}
                thumbnail={slide.thumbnail}
                external={true}
              />
            ))
          }
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
